# Base directory for all runtime data: pb_data, whatsapp.db, history, webhook.json, n8n.
# Defaults to $HOME/.zaplab when not set.
# Can also be overridden at runtime with the --data-dir flag.
# ZAPLAB_DATA_DIR=/custom/path

# REST API authentication token (required — all API calls without it return 401)
API_TOKEN=your-secret-token-here

# Cloudflare Tunnel token (from cloudflare.com > Zero Trust > Tunnels)
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# n8n webhook base URL (used by n8n to build webhook callback URLs)
# Set to your public domain when exposing n8n externally.
WEBHOOK_URL=http://localhost:5678/

# Timezone for n8n scheduler (defaults to America/Sao_Paulo)
# TZ=America/Sao_Paulo

# n8n public hostname (used for cookie/session scoping)
# N8N_HOST=localhost

# n8n protocol: http or https
# N8N_PROTOCOL=http
